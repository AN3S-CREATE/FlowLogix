# FlowLogix production environment — copy to .env.prod and fill in real secrets.
# Consumed by `docker compose -f docker-compose.prod.yml --env-file .env.prod`.
# NEVER commit the filled-in .env.prod (see .gitignore).

# ---- Container images (pushed by the deploy workflow) ----
REGISTRY=ghcr.io
IMAGE_NAMESPACE=veralogix-group-innovation/flowlogix
IMAGE_TAG=latest

# ---- Edge / TLS ----
# Host directory holding fullchain.pem + privkey.pem, mounted read-only into web.
TLS_CERT_DIR=./deploy/certs
# Public origin(s) allowed by CORS (comma-separated).
CORS_ORIGIN=https://app.veralogix.co.za

# ---- Logging ----
LOG_LEVEL=info

# ---- Postgres ----
POSTGRES_USER=logixflow
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=logixflow
# Least-privilege app role used at runtime (RLS is enforced against this role).
APP_DB_USER=logixflow_app
APP_DB_PASSWORD=change-me-app

# ---- MongoDB ----
MONGO_USER=logixflow
MONGO_PASSWORD=change-me-mongo

# ---- Redis (master/replica, password-authenticated) ----
REDIS_PASSWORD=change-me-redis

# ---- Grafana ----
GRAFANA_ADMIN_PASSWORD=change-me-grafana
GRAFANA_PORT=3001

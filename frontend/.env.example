# Frontend local env (copy to frontend/.env.local — never commit secrets)

# Nest API origin — when set, SPA requires JWT login and hydrates boards via REST
VITE_API_URL=http://localhost:3000

# Socket.io origin (optional; defaults to VITE_API_URL)
# VITE_WS_URL=http://localhost:3000

# Optional: pin a board; otherwise the first org board is opened
# VITE_BOARD_ID=

# Optional: WS handshake org when no JWT session (local tooling only)
# VITE_ORG_ID=

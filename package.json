{
  "name": "logixflow",
  "private": true,
  "version": "0.1.0",
  "description": "LogixFlow - collaborative Kanban board platform (NestJS backend + React frontend)",
  "workspaces": [
    "backend",
    "frontend",
    "mobile"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build:backend": "npm run build --workspace backend",
    "build:frontend": "npm run build --workspace frontend",
    "lint:backend": "npm run lint --workspace backend",
    "lint:frontend": "npm run lint --workspace frontend",
    "test:mobile": "npm run test --workspace mobile",
    "typecheck:mobile": "npm run typecheck --workspace mobile",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "overrides": {
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/platform-socket.io": "11.1.28",
    "@nestjs/websockets": "11.1.28",
    "@nestjs/testing": "11.1.28",
    "rxjs": "7.8.2"
  }
}

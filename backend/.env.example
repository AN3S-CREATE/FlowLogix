NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=logixflow
POSTGRES_PASSWORD=logixflow
POSTGRES_DB=logixflow

# Unprivileged role the running app connects as (created by the
# EnableRlsAndTriggers migration). Row-Level Security is bypassed for the
# POSTGRES_USER owner role above, so app queries must use this role instead
# for the boards RLS policy to be enforced.
APP_DB_USER=logixflow_app
APP_DB_PASSWORD=logixflow_app

# MongoDB
MONGO_URI=mongodb://logixflow:logixflow@localhost:27017/logixflow?authSource=admin
# When false, a down mongo probe does not fail overall /health (postgres+redis still required).
HEALTH_REQUIRE_MONGO=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Metrics ACL — unset in development keeps /health/metrics open; set to require Bearer / X-Metrics-Secret.
# METRICS_SECRET=

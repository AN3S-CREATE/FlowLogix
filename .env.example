# Values used by docker-compose.yml to provision local dev datastores.
# Copy to .env and adjust as needed: cp .env.example .env

POSTGRES_USER=logixflow
POSTGRES_PASSWORD=logixflow
POSTGRES_DB=logixflow
POSTGRES_PORT=5432

MONGO_USER=logixflow
MONGO_PASSWORD=logixflow
MONGO_DB=logixflow
MONGO_PORT=27017

REDIS_PORT=6379
# Consumed by the NestJS real-time pipeline (Redis Pub/Sub). REDIS_HOST/PORT
# build the connection URL; set REDIS_URL to override (e.g. a managed cluster).
REDIS_HOST=localhost
# REDIS_URL=redis://localhost:6379
